# =====================================================
# Student Connect - Environment Variables Template
# =====================================================
# Create a copy of this file and rename it to .env
# Do NOT commit your actual .env file to version control.
# =====================================================

# -----------------------------------------------------
# BACKEND (Spring Boot)
# -----------------------------------------------------
SERVER_PORT=8080

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL=jdbc:postgresql://<your-supabase-host>:5432/postgres
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=<your-database-password>

# --- JWT Configuration ---
# Generate a strong, unique 64-character secret for production
JWT_SECRET=<your-strong-base64-encoded-secret>
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Third-Party Services ---
# Cloudinary (File Uploads)
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# SendGrid (Email Service)
SENDGRID_API_KEY=<your-sendgrid-api-key>
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Google OAuth
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

# Supabase Storage Details
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<your-supabase-anon-key>

# -----------------------------------------------------
# FRONTEND (Next.js)
# -----------------------------------------------------
# Will be used after deployment. Currently hardcoded to localhost.
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_WS_URL=http://localhost:8080/ws
